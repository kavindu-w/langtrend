---
import { scaleBand, scaleLinear } from 'd3';
import { CLASS_LABELS, colorForIndex } from '../lib/data.js';
import { LANGUAGE_CLASS_COLORS, languageBorderClass } from '../lib/language-colors.js';

type LanguageCount = { language: string; count: number };
type WeekPoint = { date: string; papers: number; flagged: number };
type CoverageStats = { htmlScanned: number; pdfOnly: number; abstractOnly: number };
type ClassCount = { class_id: number; count: number };
type WeekAggregate = {
  weekStart: string;
  weekEnd?: string | null;
  papers: number;
  flaggedPapers: number;
  uniqueLanguages: number;
  languageCounts: LanguageCount[];
  classCounts: ClassCount[];
  dailySeries: WeekPoint[];
};

type Props = {
  languageCounts: LanguageCount[];
  classCounts: ClassCount[];
  weekSeries: WeekPoint[];
  coverageStats: CoverageStats;
  allWeeksData: WeekAggregate[];
  manifest: {
    counts?: {
      papers?: number;
      flagged_papers?: number;
      unique_languages?: number;
    };
    papers?: unknown[];
    flagged_papers?: unknown[];
    week_start?: string;
    week_end?: string;
  };
  languageData: { lang_classes?: Record<string, unknown[]> };
};

const { languageCounts = [], classCounts = [], weekSeries = [], coverageStats, allWeeksData = [], manifest, languageData } = Astro.props as Props;

const langClasses = languageData?.lang_classes || {};
const weeklyPapers = manifest.counts?.papers ?? (manifest.papers || []).length;
const weeklyFlagged = manifest.counts?.flagged_papers ?? (manifest.flagged_papers || []).length;
const weeklyUniqueLanguages = manifest.counts?.unique_languages ?? languageCounts.length;

function formatWeekRange(series: WeekPoint[], fallbackStart?: string, fallbackEnd?: string) {
  const startSource = series[0]?.date || fallbackStart;
  const endSource = series[series.length - 1]?.date || fallbackEnd || fallbackStart;
  if (!startSource || !endSource) {
    return 'the current window';
  }

  const start = new Date(`${startSource}T00:00:00`);
  const end = new Date(`${endSource}T00:00:00`);
  const startLabel = start.toLocaleDateString(undefined, { day: 'numeric', month: 'short' });
  const endLabel = end.toLocaleDateString(undefined, { day: 'numeric', month: 'short' });
  return `The Week of ${startLabel}–${endLabel}`;
}

function formatWeekLabel(weekStart: string) {
  const date = new Date(`${weekStart}T00:00:00`);
  return date.toLocaleDateString(undefined, { day: 'numeric', month: 'short' });
}

function formatWeekdayLabel(dateString: string) {
  const date = new Date(`${dateString}T00:00:00`);
  return date.toLocaleDateString(undefined, { weekday: 'short' });
}

function formatPercent(value: number, total: number) {
  if (!total) return '0%';
  return `${Math.round((value / total) * 100)}%`;
}

function sumCounts(items: { count: number }[]) {
  return items.reduce((sum, item) => sum + (item.count || 0), 0);
}

function buildLinePath(points: { x: number; y: number }[]) {
  if (!points.length) return '';
  return points.map((point, index) => `${index === 0 ? 'M' : 'L'}${point.x},${point.y}`).join(' ');
}

function classColor(language: string) {
  const index = languageBorderClass(language, langClasses);
  return LANGUAGE_CLASS_COLORS[index] || LANGUAGE_CLASS_COLORS[0];
}

function classColorForId(classId: number) {
  return LANGUAGE_CLASS_COLORS[classId] || LANGUAGE_CLASS_COLORS[0];
}

const weekLabel = formatWeekRange(weekSeries, manifest.week_start, manifest.week_end);
const weeklySummaryCards = [
  { label: 'Total papers scanned', value: weeklyPapers },
  { label: 'Papers with language mentions', value: weeklyFlagged },
  { label: 'Unique languages detected', value: weeklyUniqueLanguages },
];

const weeklyDailySeries = [...weekSeries];
const weeklyDailyWidth = 760;
const weeklyDailyHeight = 240;
const weeklyDailyMargins = { top: 24, right: 18, bottom: 52, left: 42 };
const weeklyDailyInnerWidth = weeklyDailyWidth - weeklyDailyMargins.left - weeklyDailyMargins.right;
const weeklyDailyInnerHeight = weeklyDailyHeight - weeklyDailyMargins.top - weeklyDailyMargins.bottom;
const weeklyDailyScale = scaleBand()
  .domain(weeklyDailySeries.map((item) => item.date))
  .range([0, weeklyDailyInnerWidth])
  .padding(0.22);
const weeklyDailyMax = Math.max(1, ...weeklyDailySeries.map((item) => item.papers || 0));
const weeklyDailyY = scaleLinear().domain([0, weeklyDailyMax]).nice().range([weeklyDailyInnerHeight, 0]);

const weeklyClassSeries = CLASS_LABELS.map((label, classId) => ({
  classId,
  label,
  count: classCounts.find((item) => item.class_id === classId)?.count ?? 0,
  color: classColorForId(classId),
}));
const weeklyClassTotal = Math.max(1, sumCounts(weeklyClassSeries));

const weeklyLanguageSeries = [...languageCounts]
  .sort((left, right) => {
    const countDelta = right.count - left.count;
    return countDelta !== 0 ? countDelta : left.language.localeCompare(right.language);
  })
  .slice(0, 20);
const weeklyLanguageMax = Math.max(1, ...weeklyLanguageSeries.map((item) => item.count || 0));
const weeklyLanguageBarHeight = 620;
const weeklyLanguageBarWidth = 920;
const weeklyLanguageBarMargins = { top: 18, right: 24, bottom: 20, left: 210 };
const weeklyLanguageBarInnerWidth = weeklyLanguageBarWidth - weeklyLanguageBarMargins.left - weeklyLanguageBarMargins.right;
const weeklyLanguageRowHeight = 28;
const weeklyLanguageTotalCount = Math.max(1, languageCounts.reduce((sum, item) => sum + item.count, 0));

const trendWeeks = [...allWeeksData].sort((left, right) => left.weekStart.localeCompare(right.weekStart));
const trendWeekLabels = trendWeeks.map((week) => week.weekStart);
const trendLanguageTotals = new Map<string, number>();
for (const week of trendWeeks) {
  for (const item of week.languageCounts || []) {
    if (!item.language) continue;
    trendLanguageTotals.set(item.language, (trendLanguageTotals.get(item.language) || 0) + item.count);
  }
}
const topTrendLanguages = [...trendLanguageTotals.entries()]
  .sort((left, right) => {
    const countDelta = right[1] - left[1];
    return countDelta !== 0 ? countDelta : left[0].localeCompare(right[0]);
  })
  .slice(0, 8)
  .map(([language, count], index) => ({ language, count, color: colorForIndex(index) }));

const trendGroupedWidth = 760;
const trendGroupedHeight = 260;
const trendGroupedMargins = { top: 24, right: 44, bottom: 50, left: 42 };
const trendGroupedInnerWidth = trendGroupedWidth - trendGroupedMargins.left - trendGroupedMargins.right;
const trendGroupedInnerHeight = trendGroupedHeight - trendGroupedMargins.top - trendGroupedMargins.bottom;
const trendGroupedScale = scaleBand().domain(trendWeekLabels).range([0, trendGroupedInnerWidth]).padding(0.22);
const trendGroupedMax = Math.max(1, ...trendWeeks.map((week) => week.papers || 0));
const trendGroupedY = scaleLinear().domain([0, trendGroupedMax]).nice().range([trendGroupedInnerHeight, 0]);

const trendTopLanguageWidth = 760;
const trendTopLanguageHeight = 280;
const trendTopLanguageMargins = { top: 28, right: 60, bottom: 50, left: 42 };
const trendTopLanguageInnerWidth = trendTopLanguageWidth - trendTopLanguageMargins.left - trendTopLanguageMargins.right;
const trendTopLanguageInnerHeight = trendTopLanguageHeight - trendTopLanguageMargins.top - trendTopLanguageMargins.bottom;
const trendTopLanguageScale = scaleBand().domain(trendWeekLabels).range([0, trendTopLanguageInnerWidth]).padding(0.3);
const trendTopLanguageMax = Math.max(
  1,
  ...topTrendLanguages.flatMap((item) => trendWeeks.map((week) => {
    const found = (week.languageCounts || []).find((language) => language.language === item.language);
    return found?.count || 0;
  })),
);
const trendTopLanguageY = scaleLinear().domain([0, trendTopLanguageMax]).nice().range([trendTopLanguageInnerHeight, 0]);
const trendSeries = topTrendLanguages.map((item) => {
  const points = trendWeeks.map((week) => {
    const found = (week.languageCounts || []).find((language) => language.language === item.language);
    const x = (trendTopLanguageScale(week.weekStart) || 0) + trendTopLanguageScale.bandwidth() / 2;
    return {
      x,
      y: trendTopLanguageY(found?.count || 0),
      value: found?.count || 0,
    };
  });
  return { ...item, points, path: buildLinePath(points) };
});

const trendClassWidth = 760;
const trendClassHeight = 260;
const trendClassMargins = { top: 20, right: 18, bottom: 54, left: 42 };
const trendClassInnerWidth = trendClassWidth - trendClassMargins.left - trendClassMargins.right;
const trendClassInnerHeight = trendClassHeight - trendClassMargins.top - trendClassMargins.bottom;
const trendClassScale = scaleBand().domain(trendWeekLabels).range([0, trendClassInnerWidth]).padding(0.28);
const trendClassBars = trendWeeks.map((week) => {
  const classMap = new Map((week.classCounts || []).map((item) => [item.class_id, item.count]));
  const total = Math.max(1, CLASS_LABELS.reduce((sum, _label, classId) => sum + (classMap.get(classId) || 0), 0));
  let offset = 0;
  return {
    weekStart: week.weekStart,
    total,
    segments: CLASS_LABELS.map((label, classId) => {
      const count = classMap.get(classId) || 0;
      const percentage = count / total;
      const height = trendClassInnerHeight * percentage;
      const segment = {
        classId,
        label,
        count,
        percent: percentage,
        y: trendClassInnerHeight - offset - height,
        height,
        color: classColorForId(classId),
      };
      offset += height;
      return segment;
    }),
  };
});

const trendUniqueWidth = 760;
const trendUniqueHeight = 240;
const trendUniqueMargins = { top: 24, right: 18, bottom: 50, left: 42 };
const trendUniqueInnerWidth = trendUniqueWidth - trendUniqueMargins.left - trendUniqueMargins.right;
const trendUniqueInnerHeight = trendUniqueHeight - trendUniqueMargins.top - trendUniqueMargins.bottom;
const trendUniqueScale = scaleBand().domain(trendWeekLabels).range([0, trendUniqueInnerWidth]).padding(0.22);
const trendUniqueMax = Math.max(1, ...trendWeeks.map((week) => week.uniqueLanguages || 0));
const trendUniqueY = scaleLinear().domain([0, trendUniqueMax]).nice().range([trendUniqueInnerHeight, 0]);

// Scan volume — flagged percent overlay
const trendGroupedSecondaryY = scaleLinear().domain([0, 100]).range([trendGroupedInnerHeight, 0]);
const trendGroupedFlaggedLine = trendWeeks.map(week => ({
  x: (trendGroupedScale(week.weekStart) || 0) + trendGroupedScale.bandwidth() / 2,
  y: trendGroupedSecondaryY(week.papers > 0 ? (week.flaggedPapers / week.papers) * 100 : 0),
  pct: week.papers > 0 ? Math.round((week.flaggedPapers / week.papers) * 100) : 0,
}));

// Trend line — endpoint label vertical deconfliction
const trendEndpointRaw = trendSeries.map((series, idx) => {
  const lastPt = series.points[series.points.length - 1];
  return { idx, naturalY: lastPt?.y ?? 0, value: lastPt?.value ?? 0, color: series.color };
}).sort((a, b) => a.naturalY - b.naturalY);
const trendEndpointLabelY: number[] = new Array(trendSeries.length).fill(0);
let prevEndpointY = -Infinity;
for (const item of trendEndpointRaw) {
  const y = Math.max(item.naturalY, prevEndpointY + 14);
  trendEndpointLabelY[item.idx] = y;
  prevEndpointY = y;
}

// Mirror ranking chart
const hasPrevWeek = trendWeeks.length >= 2;
const prevWeekData = hasPrevWeek ? trendWeeks[trendWeeks.length - 2] : null;
const currTop10 = [...languageCounts].sort((a, b) => b.count - a.count).slice(0, 10);
const prevTop10Sorted = prevWeekData ? [...(prevWeekData.languageCounts || [])].sort((a, b) => b.count - a.count).slice(0, 10) : [];
const mirrorPrevRankMap = new Map<string, number>(prevTop10Sorted.map((item, i) => [item.language, i + 1]));
const mirrorPrevCountMap = new Map<string, number>(prevTop10Sorted.map(item => [item.language, item.count]));
const mirrorLanguages = currTop10.map((item, i) => {
  const currRank = i + 1;
  const prevRank = mirrorPrevRankMap.get(item.language) ?? null;
  const rankDelta = prevRank !== null ? prevRank - currRank : null;
  return { language: item.language, currCount: item.count, prevCount: mirrorPrevCountMap.get(item.language) || 0, currRank, prevRank, rankDelta };
});
const mirrorMaxCount = Math.max(1, ...mirrorLanguages.flatMap(x => [x.currCount, x.prevCount]));
const mirrorSvgWidth = 920;
const mirrorSvgHeight = 360;
const mirrorCenterX = 460;
const mirrorLabelWidth = 180;
const mirrorBarLeft = 18;
const mirrorBarAreaWidth = mirrorCenterX - mirrorLabelWidth / 2 - mirrorBarLeft;
const mirrorRowHeight = 30;
const mirrorRowGap = 4;
const mirrorTopPad = 40;

// Bump chart
const bumpLanguageList = topTrendLanguages.slice(0, 8);
const bumpSvgWidth = 920;
const bumpSvgHeight = 300;
const bumpMargins = { top: 30, right: 160, bottom: 50, left: 140 };
const bumpInnerWidth = bumpSvgWidth - bumpMargins.left - bumpMargins.right;
const bumpInnerHeight = bumpSvgHeight - bumpMargins.top - bumpMargins.bottom;
const bumpMaxRank = Math.max(2, Math.min(8, bumpLanguageList.length));
const bumpYScale = scaleLinear().domain([1, bumpMaxRank]).range([0, bumpInnerHeight]);
const bumpXScale = scaleBand().domain(trendWeekLabels).range([0, bumpInnerWidth]).padding(0.5);
const bumpSeriesData = bumpLanguageList.map((lang) => {
  const pts = trendWeeks.map((week) => {
    const sorted = [...(week.languageCounts || [])].sort((a, b) => b.count - a.count);
    const pos = sorted.findIndex(x => x.language === lang.language);
    if (pos < 0 || pos >= bumpMaxRank) return null;
    const x = (bumpXScale(week.weekStart) || 0) + bumpXScale.bandwidth() / 2;
    const y = bumpYScale(pos + 1);
    return { x, y, rank: pos + 1 };
  });
  let pathD = '';
  let penDown = false;
  for (const pt of pts) {
    if (!pt) { penDown = false; continue; }
    if (!penDown) { pathD += `M ${pt.x} ${pt.y}`; penDown = true; }
    else { pathD += ` L ${pt.x} ${pt.y}`; }
  }
  const firstPt = pts.find(p => p !== null) ?? null;
  const lastPt = [...pts].reverse().find(p => p !== null) ?? null;
  return { language: lang.language, color: lang.color, pts, pathD, firstPt, lastPt };
});

// Sankey chart
const sankeyLanguages = [...languageCounts].slice(0, 8);
const showSankey = sankeyLanguages.length >= 5;
const sankeySvgWidth = 1120;
const sankeySvgHeight = 360;
const sankeyNodeWidth = 18;
const sankeyPad = 8;
const sankeyDrawHeight = 300;
const sankeyLeftNodeX = 150;
const sankeyRightNodeX = 950;
const sankeyMidX = (sankeyLeftNodeX + sankeyNodeWidth + sankeyRightNodeX) / 2;
const sankeyClassTotalMap = new Map<number, number>();
for (const item of sankeyLanguages) {
  const classId = languageBorderClass(item.language, langClasses);
  sankeyClassTotalMap.set(classId, (sankeyClassTotalMap.get(classId) || 0) + item.count);
}
const sankeyGrandTotal = Math.max(1, sankeyLanguages.reduce((s, x) => s + x.count, 0));
type SankeyLeftNode = { classId: number; label: string; total: number; color: string; y: number; height: number };
const sankeyLeftNodes: SankeyLeftNode[] = [...sankeyClassTotalMap.entries()]
  .sort((a, b) => a[0] - b[0])
  .map(([classId, total]) => ({ classId, label: CLASS_LABELS[classId] || `Class ${classId}`, total, color: classColorForId(classId), y: 0, height: 0 }));
let sankeyLeftCursor = 20;
for (const node of sankeyLeftNodes) {
  node.height = Math.max(2, (node.total / sankeyGrandTotal) * sankeyDrawHeight);
  node.y = sankeyLeftCursor;
  sankeyLeftCursor += node.height + sankeyPad;
}
type SankeyRightNode = { language: string; count: number; color: string; y: number; height: number };
const sankeyRightNodes: SankeyRightNode[] = sankeyLanguages.map(item => ({ language: item.language, count: item.count, color: classColor(item.language), y: 0, height: 0 }));
let sankeyRightCursor = 20;
for (const node of sankeyRightNodes) {
  node.height = Math.max(2, (node.count / sankeyGrandTotal) * sankeyDrawHeight);
  node.y = sankeyRightCursor;
  sankeyRightCursor += node.height + sankeyPad;
}
const sankeyClassOffsets = new Map<number, number>(sankeyLeftNodes.map(n => [n.classId, 0]));
const sankeyLangOffsets = new Map<string, number>(sankeyRightNodes.map(n => [n.language, 0]));
const sankeyPaths = sankeyLanguages.map(item => {
  const classId = languageBorderClass(item.language, langClasses);
  const leftNode = sankeyLeftNodes.find(n => n.classId === classId)!;
  const rightNode = sankeyRightNodes.find(n => n.language === item.language)!;
  const lOffset = sankeyClassOffsets.get(classId) || 0;
  const rOffset = sankeyLangOffsets.get(item.language) || 0;
  const linkH = Math.max(2, (item.count / sankeyGrandTotal) * sankeyDrawHeight);
  const srcY1 = leftNode.y + lOffset;
  const srcY2 = srcY1 + linkH;
  const tgtY1 = rightNode.y + rOffset;
  const tgtY2 = tgtY1 + linkH;
  sankeyClassOffsets.set(classId, lOffset + linkH);
  sankeyLangOffsets.set(item.language, rOffset + linkH);
  const lx = sankeyLeftNodeX + sankeyNodeWidth;
  const rx = sankeyRightNodeX;
  const d = `M ${lx} ${srcY1} C ${sankeyMidX} ${srcY1} ${sankeyMidX} ${tgtY1} ${rx} ${tgtY1} L ${rx} ${tgtY2} C ${sankeyMidX} ${tgtY2} ${sankeyMidX} ${srcY2} ${lx} ${srcY2} Z`;
  return { language: item.language, classId, d, color: classColorForId(classId), count: item.count };
});
---
<section class="stats-stack">
  <article class="panel chart-panel wide-panel">
    <div class="panel-head">
      <div>
        <h2 id="weekly-stat-title">For {weekLabel}</h2>
        <p>Weekly summary, activity timing, resource-class mix, and the top language counts.</p>
      </div>
    </div>

    <div class="stat-row">
      {weeklySummaryCards.map((card) => (
        <article class="stat-card-mini">
          <strong>{card.value}</strong>
          <span>{card.label}</span>
        </article>
      ))}
    </div>

    <div class="coverage-badges" aria-label="Source coverage summary">
      <span class="coverage-pill"><span class="coverage-dot html"></span>HTML scanned {coverageStats?.htmlScanned ?? 0}</span>
      <span class="coverage-pill"><span class="coverage-dot pdf"></span>PDF only {coverageStats?.pdfOnly ?? 0}</span>
      <span class="coverage-pill"><span class="coverage-dot abstract"></span>Abstract only {coverageStats?.abstractOnly ?? 0}</span>
    </div>

    <div class="weekly-overview-grid">
      <article class="chart-subpanel">
        <div class="chart-subpanel-head">
          <div>
            <h3>Daily submission activity</h3>
            <p>Flagged papers are stacked on top of the other papers for each day in the window.</p>
          </div>
          <span class="chart-caption">Flagged share shown above each bar</span>
        </div>
        {weeklyDailySeries.length > 0 ? (
          <div class="chart-scroll">
            <svg class="chart-svg" width="100%" height={weeklyDailyHeight} viewBox={`0 0 ${weeklyDailyWidth} ${weeklyDailyHeight}`} preserveAspectRatio="xMinYMin meet" role="img" aria-label="Daily submission activity stacked bar chart">
              <g transform={`translate(${weeklyDailyMargins.left} ${weeklyDailyMargins.top})`}>
                {weeklyDailyY.ticks(4).map((tick) => (
                  <g transform={`translate(0 ${weeklyDailyY(tick)})`}>
                    <line x1="0" x2={weeklyDailyInnerWidth} y1="0" y2="0" class="chart-grid-line"></line>
                    <text x="-10" y="4" text-anchor="end" class="chart-axis-label">{tick}</text>
                  </g>
                ))}
                {weeklyDailySeries.map((point) => {
                  const total = Math.max(point.papers || 0, 0);
                  const flagged = Math.max(Math.min(point.flagged || 0, total), 0);
                  const x = weeklyDailyScale(point.date) || 0;
                  const barWidth = weeklyDailyScale.bandwidth();
                  const totalHeight = total > 0 ? (total / weeklyDailyMax) * weeklyDailyInnerHeight : 0;
                  const flaggedHeight = total > 0 ? totalHeight * (flagged / total) : 0;
                  const nonFlaggedHeight = Math.max(totalHeight - flaggedHeight, 0);
                  const y = weeklyDailyInnerHeight - totalHeight;
                  const flaggedPercent = total > 0 ? Math.round((flagged / total) * 100) : 0;
                  return (
                    <g transform={`translate(${x} 0)`}>
                      <rect x="0" y={y} width={barWidth} height={nonFlaggedHeight} fill="rgba(32, 22, 19, 0.16)" rx="5"></rect>
                      <rect x="0" y={y + nonFlaggedHeight} width={barWidth} height={flaggedHeight} fill={LANGUAGE_CLASS_COLORS[4]} rx="5"></rect>
                      <text x={barWidth / 2} y={Math.max(y - 8, 10)} text-anchor="middle" class="chart-value">{flaggedPercent}%</text>
                      <text x={barWidth / 2} y={weeklyDailyInnerHeight + 16} text-anchor="middle" class="chart-label">{formatWeekdayLabel(point.date)}</text>
                      <text x={barWidth / 2} y={weeklyDailyInnerHeight + 30} text-anchor="middle" class="chart-label chart-label-subtle">{point.date.slice(5)}</text>
                    </g>
                  );
                })}
              </g>
            </svg>
          </div>
        ) : (
          <p class="placeholder-text">Daily submission series will appear once a weekly snapshot is available.</p>
        )}
      </article>

      <article class="chart-subpanel">
        <div class="chart-subpanel-head">
          <div>
            <h3>Resource class breakdown</h3>
            <p>Language mentions split by resource class for the selected week.</p>
          </div>
          <span class="chart-caption">Proportional by mention count</span>
        </div>
        <div class="class-bar-wrap">
          <svg class="chart-svg" width="100%" height="92" viewBox="0 0 760 92" preserveAspectRatio="xMinYMin meet" role="img" aria-label="Resource class breakdown proportional bar">
            <g transform="translate(0 24)">
              {weeklyClassSeries.map((item, index) => {
                const previous = weeklyClassSeries.slice(0, index).reduce((sum, entry) => sum + entry.count, 0);
                const width = (item.count / weeklyClassTotal) * 760;
                const xPos = (previous / weeklyClassTotal) * 760;
                const pct = weeklyClassTotal > 0 ? Math.round((item.count / weeklyClassTotal) * 100) : 0;
                return (
                  <g>
                    <clipPath id={`cls-clip-${index}`}><rect x={xPos} y="0" width={Math.max(width, 0)} height="24"></rect></clipPath>
                    <rect x={xPos} y="0" width={Math.max(width, 0)} height="24" fill={item.color}>
                      <title>{`${item.label}: ${item.count}`}</title>
                    </rect>
                    {width > 40 && (
                      <text x={xPos + width / 2} y="16" text-anchor="middle" clip-path={`url(#cls-clip-${index})`} style="fill:white;font-weight:700;font-size:11px">{pct}%</text>
                    )}
                  </g>
                );
              })}
            </g>
          </svg>
        </div>
        <ul class="class-legend">
          {weeklyClassSeries.map((item) => (
            <li>
              <span class="lang-swatch" style={`background:${item.color}`}></span>
              <span>{item.label}</span>
              <strong>{item.count}</strong>
            </li>
          ))}
        </ul>
      </article>

      <article class="chart-subpanel chart-subpanel-wide">
        <div class="chart-subpanel-head">
          <div>
            <h3>Weekly rank comparison</h3>
            <p>Top-10 languages this week versus last week — bars show mention count, badge shows rank change.</p>
          </div>
          <span class="chart-caption">← Prev week · This week →</span>
        </div>
        {hasPrevWeek && mirrorLanguages.length > 0 ? (
          <div class="chart-scroll">
            <svg class="chart-svg" width="100%" height={mirrorSvgHeight} viewBox={`0 0 ${mirrorSvgWidth} ${mirrorSvgHeight}`} preserveAspectRatio="xMinYMin meet" role="img" aria-label="Mirror rank comparison chart">
              {/* Column headers */}
              <text x={mirrorCenterX - mirrorLabelWidth / 2 - 10} y="22" text-anchor="end" class="chart-caption">PREV WEEK</text>
              <text x={mirrorCenterX} y="22" text-anchor="middle" class="chart-caption">LANGUAGE</text>
              <text x={mirrorCenterX + mirrorLabelWidth / 2 + 10} y="22" text-anchor="start" class="chart-caption">THIS WEEK</text>
              {mirrorLanguages.map((item, i) => {
                const y = mirrorTopPad + i * (mirrorRowHeight + mirrorRowGap);
                const barColor = classColor(item.language);
                const centerLeft = mirrorCenterX - mirrorLabelWidth / 2;
                const centerRight = mirrorCenterX + mirrorLabelWidth / 2;
                const prevBarWidth = (item.prevCount / mirrorMaxCount) * mirrorBarAreaWidth;
                const currBarWidth = (item.currCount / mirrorMaxCount) * mirrorBarAreaWidth;
                let badgeText = '=';
                let badgeColor = 'var(--muted)';
                if (item.rankDelta === null) { badgeText = 'NEW'; badgeColor = '#1b998b'; }
                else if (item.rankDelta > 0) { badgeText = `▲${item.rankDelta}`; badgeColor = '#1b998b'; }
                else if (item.rankDelta < 0) { badgeText = `▼${Math.abs(item.rankDelta)}`; badgeColor = '#d7263d'; }
                return (
                  <g transform={`translate(0 ${y})`}>
                    {item.prevCount > 0 && (
                      <rect x={centerLeft - prevBarWidth} y="4" width={prevBarWidth} height={mirrorRowHeight - 8} rx="4" fill={barColor} fill-opacity="0.22"></rect>
                    )}
                    {item.currCount > 0 && (
                      <rect x={centerRight} y="4" width={currBarWidth} height={mirrorRowHeight - 8} rx="4" fill={barColor} fill-opacity="0.85"></rect>
                    )}
                    <text x={mirrorCenterX - 46} y={mirrorRowHeight / 2 + 5} text-anchor="end" class="h-bar-label h-bar-label-name" style="font-size:0.78rem">{item.language}</text>
                    <text x={mirrorCenterX - 40} y={mirrorRowHeight / 2 + 5} text-anchor="start" style={`fill:${badgeColor};font-size:0.7rem;font-weight:700`}>{badgeText}</text>
                    {item.prevCount > 0 && (
                      <text x={centerLeft - prevBarWidth - 4} y={mirrorRowHeight / 2 + 4} text-anchor="end" class="chart-axis-label">{item.prevCount}</text>
                    )}
                    <text x={centerRight + currBarWidth + 4} y={mirrorRowHeight / 2 + 4} text-anchor="start" class="chart-axis-label">{item.currCount}</text>
                  </g>
                );
              })}
            </svg>
          </div>
        ) : (
          <p class="placeholder-text">Rank comparison will appear once at least two weekly snapshots are available.</p>
        )}
      </article>

      <article class="chart-subpanel chart-subpanel-wide">
        <div class="chart-subpanel-head">
          <div>
            <h3>Top-20 language frequency</h3>
            <p>Horizontal bars make the language names readable while preserving the ranking.</p>
          </div>
          <span class="chart-caption">Count and share of weekly mentions</span>
        </div>
        {weeklyLanguageSeries.length > 0 ? (
          <div class="chart-scroll">
            <svg class="chart-svg" width="100%" height={weeklyLanguageBarHeight} viewBox={`0 0 ${weeklyLanguageBarWidth} ${weeklyLanguageBarHeight}`} preserveAspectRatio="xMinYMin meet" role="img" aria-label="Top 20 language frequency horizontal bar chart">
              <g transform={`translate(${weeklyLanguageBarMargins.left} ${weeklyLanguageBarMargins.top})`}>
                {weeklyLanguageSeries.map((item, index) => {
                  const y = index * weeklyLanguageRowHeight;
                  const barWidth = (item.count / weeklyLanguageMax) * weeklyLanguageBarInnerWidth;
                  const classColorValue = classColor(item.language);
                  return (
                    <g transform={`translate(0 ${y})`}>
                      <text x={-12} y={16} text-anchor="end" class="h-bar-label h-bar-label-name">{item.language}</text>
                      <rect x="0" y="3" width={barWidth} height="18" rx="4" fill={classColorValue} fill-opacity="0.18"></rect>
                      <rect x="0" y="3" width="4" height="18" rx="2" fill={classColorValue}></rect>
                      <text x={weeklyLanguageBarInnerWidth + 10} y="16" text-anchor="start" class="h-bar-label h-bar-label-count">{item.count} ({formatPercent(item.count, weeklyLanguageTotalCount)})</text>
                    </g>
                  );
                })}
              </g>
            </svg>
          </div>
        ) : (
          <p class="placeholder-text">Top languages will appear here once language mentions are available.</p>
        )}
      </article>

      <article class="chart-subpanel chart-subpanel-wide">
        <div class="chart-subpanel-head">
          <div>
            <h3>Class → language flow</h3>
            <p>Each band shows how mentions flow from a resource class (left) to a specific language (right).</p>
          </div>
          <span class="chart-caption">Width ∝ mention count</span>
        </div>
        {showSankey ? (
          <div class="chart-scroll">
            <svg class="chart-svg" width="100%" height={sankeySvgHeight} viewBox={`0 0 ${sankeySvgWidth} ${sankeySvgHeight}`} preserveAspectRatio="xMinYMin meet" role="img" aria-label="Sankey diagram of class to language flow">
              <g transform="translate(0 0)">
                {sankeyPaths.map(link => (
                  <path d={link.d} fill={link.color} fill-opacity="0.3" stroke={link.color} stroke-width="0.5" stroke-opacity="0.4">
                    <title>{`${CLASS_LABELS[link.classId] || `Class ${link.classId}`} → ${link.language}: ${link.count}`}</title>
                  </path>
                ))}
                {sankeyLeftNodes.map(node => (
                  <g>
                    <rect x={sankeyLeftNodeX} y={node.y} width={sankeyNodeWidth} height={node.height} fill={node.color} rx="2"></rect>
                    <text x={sankeyLeftNodeX - 8} y={node.y + node.height / 2 + 4} text-anchor="end" class="chart-axis-label" style={`fill:${node.color};font-weight:700`}>{node.label}</text>
                    <text x={sankeyLeftNodeX - 8} y={node.y + node.height / 2 + 16} text-anchor="end" class="chart-axis-label">{node.total}</text>
                  </g>
                ))}
                {sankeyRightNodes.map(node => (
                  <g>
                    <rect x={sankeyRightNodeX} y={node.y} width={sankeyNodeWidth} height={node.height} fill={node.color} rx="2"></rect>
                    <text x={sankeyRightNodeX + sankeyNodeWidth + 8} y={node.y + node.height / 2 + 4} text-anchor="start" class="chart-axis-label" style={`fill:${node.color};font-weight:700`}>{node.language}</text>
                    <text x={sankeyRightNodeX + sankeyNodeWidth + 8} y={node.y + node.height / 2 + 16} text-anchor="start" class="chart-axis-label">{node.count}</text>
                  </g>
                ))}
              </g>
            </svg>
          </div>
        ) : (
          <p class="placeholder-text">Flow diagram will appear once at least 5 languages are detected.</p>
        )}
      </article>
    </div>
  </article>

  <article class="panel chart-panel wide-panel">
    <div class="panel-head">
      <div>
        <h2>Overall trends</h2>
        <p>Aggregated across all available weeks.</p>
      </div>
    </div>

    <div class="overall-trend-grid">
      <article class="chart-subpanel">
        <div class="chart-subpanel-head">
          <div>
            <h3>Weekly scan volume</h3>
            <p>Total papers versus flagged papers in each weekly snapshot.</p>
          </div>
          <span class="chart-caption">Flagged bars sit beside total bars</span>
        </div>
        {trendWeeks.length > 0 ? (
          <svg class="chart-svg" width="100%" height={trendGroupedHeight} viewBox={`0 0 ${trendGroupedWidth} ${trendGroupedHeight}`} preserveAspectRatio="xMinYMin meet" role="img" aria-label="Grouped bar chart of weekly scan volume">
            <g transform={`translate(${trendGroupedMargins.left} ${trendGroupedMargins.top})`}>
              {trendGroupedY.ticks(4).map((tick) => (
                <g transform={`translate(0 ${trendGroupedY(tick)})`}>
                  <line x1="0" x2={trendGroupedInnerWidth} y1="0" y2="0" class="chart-grid-line"></line>
                  <text x="-10" y="4" text-anchor="end" class="chart-axis-label">{tick}</text>
                </g>
              ))}
              {trendWeeks.map((week) => {
                const x = trendGroupedScale(week.weekStart) || 0;
                const barWidth = trendGroupedScale.bandwidth();
                const totalBarWidth = barWidth * 0.38;
                const flaggedBarWidth = barWidth * 0.38;
                const totalX = x + barWidth * 0.08;
                const flaggedX = x + barWidth * 0.54;
                const totalHeight = (week.papers / trendGroupedMax) * trendGroupedInnerHeight;
                const flaggedHeight = (week.flaggedPapers / trendGroupedMax) * trendGroupedInnerHeight;
                return (
                  <g>
                    <rect x={totalX} y={trendGroupedInnerHeight - totalHeight} width={totalBarWidth} height={totalHeight} fill="rgba(32, 22, 19, 0.18)" rx="5"></rect>
                    <rect x={flaggedX} y={trendGroupedInnerHeight - flaggedHeight} width={flaggedBarWidth} height={flaggedHeight} fill={LANGUAGE_CLASS_COLORS[4]} rx="5"></rect>
                    <text x={totalX + totalBarWidth / 2} y={Math.max(trendGroupedInnerHeight - totalHeight - 8, 10)} text-anchor="middle" class="chart-value">{week.papers}</text>
                    <text x={flaggedX + flaggedBarWidth / 2} y={Math.max(trendGroupedInnerHeight - flaggedHeight - 8, 10)} text-anchor="middle" class="chart-value">{week.flaggedPapers}</text>
                    <text x={x + barWidth / 2} y={trendGroupedInnerHeight + 18} text-anchor="middle" class="chart-label">{formatWeekLabel(week.weekStart)}</text>
                  </g>
                );
              })}
              {trendGroupedFlaggedLine.length > 1 && (
                <path d={buildLinePath(trendGroupedFlaggedLine)} fill="none" stroke={LANGUAGE_CLASS_COLORS[4]} stroke-width="2" opacity="0.85"></path>
              )}
              {trendGroupedFlaggedLine.map(pt => (
                <circle cx={pt.x} cy={pt.y} r="3.5" fill={LANGUAGE_CLASS_COLORS[4]} stroke="white" stroke-width="1.2"></circle>
              ))}
              {[0, 50, 100].map(pct => (
                <g transform={`translate(0 ${trendGroupedSecondaryY(pct)})`}>
                  <text x={trendGroupedInnerWidth + 6} y="4" text-anchor="start" class="chart-axis-label">{pct}%</text>
                </g>
              ))}
            </g>
          </svg>
        ) : (
          <p class="placeholder-text">Weekly scan volume will appear once multiple snapshots are available.</p>
        )}
        <div class="chart-legend-inline">
          <span><span class="coverage-dot abstract"></span>Total papers</span>
          <span><span class="coverage-dot html"></span>Flagged papers</span>
        </div>
      </article>

      <article class="chart-subpanel">
        <div class="chart-subpanel-head">
          <div>
            <h3>Top-language trends</h3>
            <p>One line per top language, selected from the combined multi-week counts.</p>
          </div>
          <span class="chart-caption">Legend shown on the right</span>
        </div>
        {trendWeeks.length > 0 && topTrendLanguages.length > 0 ? (
          <div class="trend-line-layout">
            <svg class="chart-svg" width="100%" height={trendTopLanguageHeight} viewBox={`0 0 ${trendTopLanguageWidth} ${trendTopLanguageHeight}`} preserveAspectRatio="xMinYMin meet" role="img" aria-label="Line chart of top-language trends across weeks">
              <g transform={`translate(${trendTopLanguageMargins.left} ${trendTopLanguageMargins.top})`}>
                {trendTopLanguageY.ticks(4).map((tick) => (
                  <g transform={`translate(0 ${trendTopLanguageY(tick)})`}>
                    <line x1="0" x2={trendTopLanguageInnerWidth} y1="0" y2="0" class="chart-grid-line"></line>
                    <text x="-10" y="4" text-anchor="end" class="chart-axis-label">{tick}</text>
                  </g>
                ))}
                {trendSeries.map((series, idx) => {
                  const lastPt = series.points[series.points.length - 1];
                  return (
                    <g>
                      <path d={series.path} fill="none" stroke={series.color} stroke-width="2.5"></path>
                      {series.points.map((point) => (
                        <circle cx={point.x} cy={point.y} r="3.5" fill={series.color} stroke="white" stroke-width="1.2"></circle>
                      ))}
                      {lastPt && lastPt.value > 0 && (
                        <text x={lastPt.x + 7} y={trendEndpointLabelY[idx] + 4} class="chart-axis-label" style={`fill:${series.color};font-weight:700`}>{lastPt.value}</text>
                      )}
                    </g>
                  );
                })}
                {trendWeeks.map((week) => {
                  const x = trendTopLanguageScale(week.weekStart) || 0;
                  return (
                    <text x={x + trendTopLanguageScale.bandwidth() / 2} y={trendTopLanguageInnerHeight + 18} text-anchor="middle" class="chart-label">{formatWeekLabel(week.weekStart)}</text>
                  );
                })}
              </g>
            </svg>
            <div class="trend-legend">
              {trendSeries.map((series) => (
                <div class="trend-legend-item">
                  <span class="trend-legend-swatch" style={`background:${series.color}`}></span>
                  <span>{series.language}</span>
                  <strong>{series.count}</strong>
                </div>
              ))}
            </div>
          </div>
        ) : (
          <p class="placeholder-text">Multi-week language trend lines will appear after more than one weekly snapshot is available.</p>
        )}
      </article>

      <article class="chart-subpanel">
        <div class="chart-subpanel-head">
          <div>
            <h3>Resource class mix by week</h3>
            <p>Each weekly bar is normalized to 100% to compare class mix over time.</p>
          </div>
          <span class="chart-caption">100% stacked bars</span>
        </div>
        {trendWeeks.length > 0 ? (
          <svg class="chart-svg" width="100%" height={trendClassHeight} viewBox={`0 0 ${trendClassWidth} ${trendClassHeight}`} preserveAspectRatio="xMinYMin meet" role="img" aria-label="100 percent stacked bar chart of resource class mix by week">
            <g transform={`translate(${trendClassMargins.left} ${trendClassMargins.top})`}>
              {trendWeeks.map((week, index) => {
                const x = trendClassScale(week.weekStart) || 0;
                const barWidth = trendClassScale.bandwidth();
                const bar = trendClassBars[index];
                return (
                  <g>
                    {bar.segments.map((segment) => (
                      <rect x={x} y={segment.y} width={barWidth} height={Math.max(segment.height, 0)} fill={segment.color}>
                        <title>{`${segment.label}: ${segment.count}`}</title>
                      </rect>
                    ))}
                    <text x={x + barWidth / 2} y={trendClassInnerHeight + 18} text-anchor="middle" class="chart-label">{formatWeekLabel(week.weekStart)}</text>
                  </g>
                );
              })}
            </g>
          </svg>
        ) : (
          <p class="placeholder-text">Class mix will appear once multiple weekly snapshots are available.</p>
        )}
        <div class="class-legend">
          {CLASS_LABELS.map((label, classId) => (
            <div class="class-legend-item">
              <span class="trend-legend-swatch" style={`background:${classColorForId(classId)}`}></span>
              <span>{label}</span>
            </div>
          ))}
        </div>
      </article>

      <article class="chart-subpanel">
        <div class="chart-subpanel-head">
          <div>
            <h3>Unique languages per week</h3>
            <p>Shows how broad the weekly language coverage is across snapshots.</p>
          </div>
          <span class="chart-caption">Simple breadth indicator</span>
        </div>
        {trendWeeks.length > 0 ? (
          <svg class="chart-svg" width="100%" height={trendUniqueHeight} viewBox={`0 0 ${trendUniqueWidth} ${trendUniqueHeight}`} preserveAspectRatio="xMinYMin meet" role="img" aria-label="Bar chart of unique languages per week">
            <g transform={`translate(${trendUniqueMargins.left} ${trendUniqueMargins.top})`}>
              {trendUniqueY.ticks(4).map((tick) => (
                <g transform={`translate(0 ${trendUniqueY(tick)})`}>
                  <line x1="0" x2={trendUniqueInnerWidth} y1="0" y2="0" class="chart-grid-line"></line>
                  <text x="-10" y="4" text-anchor="end" class="chart-axis-label">{tick}</text>
                </g>
              ))}
              {trendWeeks.map((week) => {
                const x = trendUniqueScale(week.weekStart) || 0;
                const barWidth = trendUniqueScale.bandwidth();
                const barHeight = (week.uniqueLanguages / trendUniqueMax) * trendUniqueInnerHeight;
                return (
                  <g>
                    <rect x={x} y={trendUniqueInnerHeight - barHeight} width={barWidth} height={barHeight} fill={LANGUAGE_CLASS_COLORS[3]} rx="5"></rect>
                    <text x={x + barWidth / 2} y={Math.max(trendUniqueInnerHeight - barHeight - 8, 10)} text-anchor="middle" class="chart-value">{week.uniqueLanguages}</text>
                    <text x={x + barWidth / 2} y={trendUniqueInnerHeight + 18} text-anchor="middle" class="chart-label">{formatWeekLabel(week.weekStart)}</text>
                  </g>
                );
              })}
            </g>
          </svg>
        ) : (
          <p class="placeholder-text">Unique-language counts will appear once multiple weekly snapshots are available.</p>
        )}
      </article>

      <article class="chart-subpanel chart-subpanel-wide">
        <div class="chart-subpanel-head">
          <div>
            <h3>Language rank trajectory</h3>
            <p>Rank 1 = most mentions in that week. Tracks the top 8 languages across all available weeks.</p>
          </div>
          <span class="chart-caption">Bump chart — rank 1 at top</span>
        </div>
        {trendWeeks.length >= 2 && bumpSeriesData.length > 0 ? (
          <div class="chart-scroll">
            <svg class="chart-svg" width="100%" height={bumpSvgHeight} viewBox={`0 0 ${bumpSvgWidth} ${bumpSvgHeight}`} preserveAspectRatio="xMinYMin meet" role="img" aria-label="Language rank bump chart across weeks">
              <g transform={`translate(${bumpMargins.left} ${bumpMargins.top})`}>
                {Array.from({ length: bumpMaxRank }, (_, i) => i + 1).map(rank => (
                  <line x1="0" x2={bumpInnerWidth} y1={bumpYScale(rank)} y2={bumpYScale(rank)} class="chart-grid-line"></line>
                ))}
                {trendWeeks.map(week => (
                  <text x={(bumpXScale(week.weekStart) || 0) + bumpXScale.bandwidth() / 2} y={bumpInnerHeight + 22} text-anchor="middle" class="chart-label">{formatWeekLabel(week.weekStart)}</text>
                ))}
                {bumpSeriesData.map(series => (
                  <g>
                    {series.pathD && <path d={series.pathD} fill="none" stroke={series.color} stroke-width="2.5" stroke-linejoin="round"></path>}
                    {series.pts.map(pt => pt && (
                      <g>
                        <circle cx={pt.x} cy={pt.y} r="14" fill={series.color}></circle>
                        <text x={pt.x} y={pt.y + 5} text-anchor="middle" style="fill:white;font-size:0.65rem;font-weight:700">{pt.rank}</text>
                      </g>
                    ))}
                    {series.firstPt && (
                      <text x={-8} y={series.firstPt.y + 5} text-anchor="end" class="chart-axis-label" style={`fill:${series.color};font-weight:700`}>{series.language}</text>
                    )}
                    {series.lastPt && (
                      <text x={bumpInnerWidth + 8} y={series.lastPt.y + 5} text-anchor="start" class="chart-axis-label" style={`fill:${series.color};font-weight:700`}>{series.language}</text>
                    )}
                  </g>
                ))}
              </g>
            </svg>
          </div>
        ) : (
          <p class="placeholder-text">Language rank trajectory will appear once multiple weekly snapshots are available.</p>
        )}
      </article>
    </div>
  </article>
</section>
