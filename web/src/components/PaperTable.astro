---
import { languageBorderClass, languageFillColor } from '../lib/language-colors.js';

type LanguageEntry = string | [string, number] | { language?: string | null; class?: number; name?: string; needs_review?: boolean; flag_reason?: string; sources?: string[] };
type PaperRecord = {
  id?: string;
  title: string;
  authors: string[];
  abstract: string;
  pdf_url: string;
  published?: string;
  updated?: string;
  categories?: string[];
};
type SectionRecord = {
  name: string;
  source: string;
  detected_languages: LanguageEntry[];
};
type PaperWarning = {
  step: string;
  acronym?: string;
  language?: string;
  language_class?: number;
  message?: string;
};
type FlaggedPaper = {
  paper: PaperRecord;
  languages: LanguageEntry[];
  sourcesChecked: string[];
  sections: SectionRecord[];
  warnings?: PaperWarning[];
};

const { flaggedPapers } = Astro.props as { flaggedPapers: FlaggedPaper[] };
const { languageData } = Astro.props as { flaggedPapers: FlaggedPaper[]; languageData?: { lang_classes?: Record<string, unknown[]> } };

const normalizeLanguage = (entry: LanguageEntry): string => {
  if (typeof entry === 'string') return entry;
  if (Array.isArray(entry)) return entry[0] ?? '';
  return entry?.language ?? entry?.name ?? '';
};
const classFromEntry = (entry: LanguageEntry): number | null => {
  if (Array.isArray(entry) && typeof entry[1] === 'number') return entry[1];
  if (!Array.isArray(entry) && typeof entry === 'object' && entry && typeof entry.class === 'number') return entry.class;
  return null;
};
const sourcesOfEntry = (entry: LanguageEntry): string[] => {
  if (typeof entry === 'string' || Array.isArray(entry)) return [];
  return (entry as { sources?: string[] }).sources ?? [];
};

const formatSectionTitle = (sectionName: string): string => {
  const compact = sectionName.replace(/\s+/g, ' ').trim();
  if (!compact) return 'Untitled section';

  const appendixMatch = compact.match(/^(Appendix\s+[A-Z])(?=[A-Z0-9])/);
  if (appendixMatch) {
    const prefix = appendixMatch[1];
    const suffix = compact.slice(prefix.length).replace(/^[\s.]+/, '');
    return suffix ? `${prefix}. ${suffix}` : prefix;
  }

  const numberedMatch = compact.match(/^((?:[A-Z]\.?\d+(?:\.\d+)*|\d+(?:\.\d+)*|[A-Z]))(?=[A-Z])/);
  if (numberedMatch) {
    const prefix = numberedMatch[1].replace(/\.$/, '');
    const suffix = compact.slice(numberedMatch[1].length).replace(/^[\s.]+/, '');
    return suffix ? `${prefix}. ${suffix}` : prefix;
  }

  return compact;
};

const chipFromEntry = (entry: LanguageEntry, langClasses: Record<string, unknown[]>): ChipEntry => {
  const language = normalizeLanguage(entry);
  const explicitNeeds = !Array.isArray(entry) && typeof entry === 'object' && !!entry?.needs_review;
  const explicitReason = !Array.isArray(entry) && typeof entry === 'object' ? (entry?.flag_reason ?? '') : '';
  const twoLetterCode = typeof language === 'string' && /^[A-Za-z]{2}$/.test(language.trim());
  // Check language_data possible_false_positive_languages map (if provided by loader)
  const pfpMap = (languageData as any)?.possible_false_positive_languages ?? {};
  const pfpReason = typeof language === 'string' && pfpMap[language] ? String(pfpMap[language]) : '';
  const needsReview = explicitNeeds || twoLetterCode || !!pfpReason;
  const flagReason = explicitReason || pfpReason || (twoLetterCode ? 'Detected as 2-letter language code — confirm mapping/label.' : '');
  return {
    language,
    borderClass: classFromEntry(entry) ?? languageBorderClass(language, langClasses),
    needsReview,
    flagReason,
    fillColor: languageFillColor(language),
  };
};

const langClasses = languageData?.lang_classes ?? {};
const languageCounts = new Map<string, number>();
for (const item of flaggedPapers) {
  for (const entry of item.languages) {
    const language = normalizeLanguage(entry);
    if (!language) continue;
    languageCounts.set(language, (languageCounts.get(language) || 0) + 1);
  }
}
const languages = [...languageCounts.entries()]
  .sort((l, r) => { const d = r[1] - l[1]; return d !== 0 ? d : l[0].localeCompare(r[0]); })
  .map(([language]) => language);

function formatDate(iso: string | undefined): string {
  if (!iso) return '';
  try { return new Date(iso).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' }); }
  catch { return iso; }
}

const SOURCE_LABEL: Record<string, string> = { abstract: 'Abstract', html: 'Full Text (HTML)', pdf: 'Full Text (PDF)' };
const SOURCE_ORDER = ['abstract', 'html', 'pdf'];

type SourceGroup = { src: string; label: string; langs: string[] };
type ChipEntry = { language: string; borderClass: number; needsReview: boolean; flagReason: string; fillColor: string };
type SectionItem = { name: string; label: string; source: string; sourceLabel: string; chips: ChipEntry[] };
type SuppressedChip = { language: string; borderClass: number; acronyms: string[] };
type PaperItem = {
  index: number;
  paper: PaperRecord;
  allAuthors: string;
  chips: ChipEntry[];
  chipLanguageNames: string[];
  minClass: number;
  hasPdf: boolean;
  coverageBadge: { label: string; title: string } | null;
  searchText: string;
  sourcesGroups: SourceGroup[];
  sections: SectionItem[];
  pubDateStr: string;
  updDateStr: string;
  showUpdated: boolean;
  arxivUrl: string;
  acronymConflicts: PaperWarning[];
  suppressedChips: SuppressedChip[];
};

const paperItems: PaperItem[] = flaggedPapers.map((item, index) => {
  const paper = item.paper;
  const allAuthors = Array.isArray(paper.authors) && paper.authors.length > 0 ? paper.authors.join(', ') : 'Unknown authors';

  const chipLanguages = [...item.languages].filter(Boolean).sort((l, r) => {
    const lc = classFromEntry(l) ?? languageBorderClass(normalizeLanguage(l), langClasses);
    const rc = classFromEntry(r) ?? languageBorderClass(normalizeLanguage(r), langClasses);
    const d = rc - lc;
    return d !== 0 ? d : normalizeLanguage(l).localeCompare(normalizeLanguage(r));
  });

  const chips: ChipEntry[] = chipLanguages.map(entry => chipFromEntry(entry, langClasses));

  const chipLanguageNames = chips.map(c => c.language).filter(Boolean);
  const minClass = chips.length > 0 ? chips.reduce((min, c) => Math.min(min, c.borderClass), 5) : 5;

  const sources = item.sourcesChecked ?? [];
  const hasHtml = sources.includes('html');
  const hasPdf = sources.includes('pdf');
  const coverageBadge = !hasHtml
    ? (hasPdf
        ? { label: 'PDF & Abstract', title: 'HTML version could not be extracted — analysis done with PDF and abstract' }
        : { label: 'Abstract only', title: 'HTML and PDF versions could not be extracted — analysis done with abstract only' })
    : null;

  const searchText = `${paper.title} ${paper.authors.join(' ')}`.toLowerCase();

  const sourcesMap = new Map<string, string[]>();
  for (const entry of chipLanguages) {
    const lang = normalizeLanguage(entry);
    if (!lang) continue;
    for (const src of sourcesOfEntry(entry)) {
      if (!sourcesMap.has(src)) sourcesMap.set(src, []);
      sourcesMap.get(src)!.push(lang);
    }
  }
  const sourcesGroups: SourceGroup[] = [...sourcesMap.entries()]
    .sort(([a], [b]) => {
      const ai = SOURCE_ORDER.indexOf(a);
      const bi = SOURCE_ORDER.indexOf(b);
      return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
    })
    .map(([src, langs]) => ({ src, label: SOURCE_LABEL[src] ?? src, langs }));

  const sections: SectionItem[] = (item.sections || [])
    .filter((section) => section?.name)
    .map((section) => ({
      name: section.name,
      label: formatSectionTitle(section.name),
      source: section.source,
      sourceLabel: SOURCE_LABEL[section.source] ?? section.source,
      chips: (section.detected_languages || [])
        .filter(Boolean)
        .map((entry) => chipFromEntry(entry, langClasses))
        .sort((left, right) => {
          const classDelta = right.borderClass - left.borderClass;
          return classDelta !== 0 ? classDelta : left.language.localeCompare(right.language);
        }),
    }));

  const pubDateStr = formatDate(paper.published);
  const updDateStr = formatDate(paper.updated);
  const pubDay = paper.published ? paper.published.slice(0, 10) : '';
  const updDay = paper.updated ? paper.updated.slice(0, 10) : '';
  const showUpdated = !!updDay && updDay !== pubDay;
  const arxivUrl = paper.id ? paper.id.replace('http://', 'https://') : paper.pdf_url;

  const acronymConflicts = (item.warnings ?? []).filter(w => w.step === 'acronym_language_conflict');

  // Languages that were fully suppressed (not in any detected chip). Group by language so
  // multiple acronyms that suppress the same language collapse into one chip.
  const suppressedByLang = new Map<string, SuppressedChip>();
  for (const w of acronymConflicts) {
    if (!w.language || !w.acronym) continue;
    if (chipLanguageNames.includes(w.language)) continue; // already shown as a real chip
    if (!suppressedByLang.has(w.language)) {
      suppressedByLang.set(w.language, {
        language: w.language,
        borderClass: w.language_class ?? 0,
        acronyms: [],
      });
    }
    const entry = suppressedByLang.get(w.language)!;
    if (!entry.acronyms.includes(w.acronym)) entry.acronyms.push(w.acronym);
  }
  const suppressedChips = [...suppressedByLang.values()];

  return { index, paper, allAuthors, chips, chipLanguageNames, minClass, hasPdf, coverageBadge, searchText, sourcesGroups, sections, pubDateStr, updDateStr, showUpdated, arxivUrl, acronymConflicts, suppressedChips };
});
---
<section class="panel paper-panel">
  <div id="active-filters-bar" class="active-filters-bar" style="display:none">
    <button id="clear-filters-btn" class="clear-filters-btn" type="button">
      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.8" stroke-linecap="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      Clear filters
    </button>
    <span id="active-filter-tags" class="active-filter-tags"></span>
  </div>
  <div class="paper-controls-bar">
    <div class="search-wrapper paper-search-wrapper">
      <svg class="input-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input id="paper-search" class="search-input" type="search" placeholder="Search by title or author" aria-label="Search papers by title or author" />
    </div>
    <div class="search-wrapper lang-search-wrapper">
      <svg class="input-icon" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <input id="lang-search" class="search-input lang-search-input" type="search" placeholder="Search languages…" aria-label="Filter language chips" />
    </div>
    <div class="paper-controls-right">
      <div class="sort-wrapper">
        <svg class="input-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/>
        </svg>
        <label class="sr-only" for="paper-sort">Sort papers</label>
        <select id="paper-sort" class="sort-select">
          <optgroup label="Sort">
            <option value="default">Newest first (arXiv order)</option>
            <option value="lang-desc">Most languages (count ↓)</option>
            <option value="lang-asc">Fewest languages (count ↑)</option>
            <option value="resource-asc">Low-resource first (class 0→5)</option>
            <option value="resource-desc">High-resource first (class 5→0)</option>
            <option value="title-asc">Title A–Z</option>
            <option value="title-desc">Title Z–A</option>
          </optgroup>
          <optgroup label="Filter by class">
            <option value="class-0">Class 0</option>
            <option value="class-1">Class 1</option>
            <option value="class-2">Class 2</option>
            <option value="class-3">Class 3</option>
            <option value="class-4">Class 4</option>
            <option value="class-5">Class 5</option>
          </optgroup>
        </select>
      </div>
      <span id="result-count" class="result-count" aria-live="polite" aria-atomic="true"></span>
    </div>
  </div>

  <div class="chip-area" id="chip-area">
    <div class="chip-row-wrapper" id="chip-row-wrapper">
      <div class="chip-row" id="language-filters">
        <button class="chip active" type="button" data-lang="all">All</button>
        {languages.map((language) => (
          <button
            class={`chip lang-filter-chip class-${languageBorderClass(language, langClasses)}`}
            type="button"
            data-lang={language}
            style={`background:${languageFillColor(language)}`}
          >
            {language} <span class="chip-count">({languageCounts.get(language) || 0})</span>
          </button>
        ))}
        <button id="chip-expand-btn" class="chip-expand-btn" type="button" aria-expanded="false" aria-label="Show more language filters" style="display:none">… +0 more</button>
      </div>
    </div>
  </div>

  <div class="paper-list" id="paper-list">
    {paperItems.map((item) => (
      <div class="paper-row-wrap">
        <details
          class="paper-row"
          data-search={item.searchText}
          data-languages={item.chipLanguageNames.join('|')}
          data-lang-count={item.chipLanguageNames.length}
          data-min-class={item.minClass}
          data-classes={[...new Set(item.chips.map(c => c.borderClass))].join(',')}
          data-title={item.paper.title.toLowerCase()}
          data-index={item.index}
        >
          <summary class="paper-summary">
            <div class="paper-main">
              <div class="paper-title-row">
                <h3>{item.paper.title}</h3>
              </div>
            <p class="paper-authors">{item.allAuthors}</p>
            <div class="paper-tags">
              {item.chips.map((chip, chipIdx) => (
                chip.needsReview ? (
                  <span class="lang-chip-popover">
                    <span class={`lang-chip class-${chip.borderClass} needs-review`} style={`background:${chip.fillColor}`} aria-describedby={`chip-tip-${item.index}-${chipIdx}`}>
                      {chip.language}<span class="review-star" aria-hidden="true">★</span>
                    </span>
                    <div class="review-popover-body" id={`chip-tip-${item.index}-${chipIdx}`} role="tooltip">
                      <strong>⚠ Manual verification may be needed</strong>
                      {chip.flagReason && <p>{chip.flagReason}</p>}
                    </div>
                  </span>
                ) : (
                  <span class={`lang-chip class-${chip.borderClass}`} style={`background:${chip.fillColor}`}>{chip.language}</span>
                )
              ))}
              {item.coverageBadge && (
                <span class="lang-chip-popover">
                  <span class={`coverage-badge${item.hasPdf ? ' pdf-only' : ' abstract-only'}`} aria-describedby={`coverage-tip-${item.index}`}>
                    {item.coverageBadge.label}
                  </span>
                  <div class="review-popover-body" id={`coverage-tip-${item.index}`} role="tooltip">
                    <strong>⚠ {item.coverageBadge.label}</strong>
                    <p>{item.coverageBadge.title}</p>
                  </div>
                </span>
              )}
              {item.suppressedChips.map((sc, scIdx) => (
                <span class="lang-chip-popover">
                  <span class={`lang-chip class-${sc.borderClass} suppressed`} aria-describedby={`suppressed-tip-${item.index}-${scIdx}`}>
                    {sc.language}<span class="suppressed-mark" aria-hidden="true">?</span>
                  </span>
                  <div class="review-popover-body" id={`suppressed-tip-${item.index}-${scIdx}`} role="tooltip">
                    <strong>Potentially suppressed</strong>
                    <p>This paper defines <code>{sc.acronyms.join(', ')}</code> as {sc.acronyms.length === 1 ? 'an acronym' : 'acronyms'} — mentions of <em>{sc.language}</em> may not have been detected.</p>
                  </div>
                </span>
              ))}
            </div>
          </div>
        </summary>
        <div class="paper-body">
          {(item.pubDateStr || (item.paper.categories && item.paper.categories.length > 0)) && (
            <div class="paper-meta">
              {item.pubDateStr && <span class="paper-date">Published {item.pubDateStr}</span>}
              {item.showUpdated && <span class="paper-meta-sep">·</span>}
              {item.showUpdated && <span class="paper-date">Updated {item.updDateStr}</span>}
              {item.paper.categories && item.paper.categories.length > 0 && (
                <span class="paper-categories">
                  {item.paper.categories.map((cat: string) => (
                    <span class="category-badge">{cat}</span>
                  ))}
                </span>
              )}
            </div>
          )}
          <strong class="paper-abstract-label">Abstract</strong>
          <p class="paper-abstract">{item.paper.abstract}</p>
          {item.acronymConflicts.length > 0 && (
            <div class="acronym-conflict-notice">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              <span>
                <strong>Manual review may be needed:</strong>{' '}
                {item.acronymConflicts.map((w, i) => (
                  <span>
                    {i > 0 && ' · '}
                    This paper defines <code>{w.acronym}</code> as an acronym — mentions of the language <em>{w.language}</em> (class {w.language_class}) may have been suppressed.
                  </span>
                ))}
              </span>
            </div>
          )}
          {item.sourcesGroups.length > 0 && (
            <details class="lang-sources-summary">
              <summary class="lang-sources-toggle">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="lang-sources-chevron"><polyline points="9 18 15 12 9 6"/></svg>
                Language detection sources
              </summary>
              <div class="lang-sources-body">
                {item.sourcesGroups
                  .filter((g) => g.src !== 'abstract')
                  .map((g) => (
                    <div class="lang-source-row">
                      <span class="lang-source-label">{g.label}:</span>
                      <span class="lang-source-langs">{g.langs.join(', ')}</span>
                      {g.src === 'html' && item.sections && item.sections.length > 0 && (
                        <details class="html-sections-list">
                          <summary class="html-sections-summary">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="html-sections-chevron"><polyline points="9 18 15 12 9 6"/></svg>
                            Section-wise breakdown
                          </summary>
                          <div class="html-sections-body">
                            {item.sections
                              .filter((s) => s.source === 'html')
                              .map((s) => (
                                <div class="html-section-item">
                                  <div class="html-section-title"><strong>{formatSectionTitle(s.name)}</strong></div>
                                  <div class="html-section-langs">{Array.from(new Set((s.chips || []).map(c => c.language).filter(Boolean))).join(', ')}</div>
                                </div>
                              ))}
                          </div>
                        </details>
                      )}
                    </div>
                  ))}
              </div>
            </details>
          )}
          <!-- Section-level details moved into the Language detection sources block above. -->
          <div class="paper-body-footer">
            <a class="arxiv-link" href={item.arxivUrl} target="_blank" rel="noreferrer">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              View on arXiv<span class="sr-only"> (opens in new tab)</span>
            </a>
          </div>
        </div>
        </details>
        <a class="pdf-link" href={item.paper.pdf_url} target="_blank" rel="noreferrer" aria-label={`PDF — ${item.paper.title} (opens in new tab)`}>
          <svg class="pdf-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7zm0 1.5V8h4.5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
          </svg>
          <span aria-hidden="true">PDF</span>
        </a>
      </div>
    ))}
  </div>
</section>

<script>
  const searchInput = document.getElementById('paper-search') as HTMLInputElement | null;
  const langSearchInput = document.getElementById('lang-search') as HTMLInputElement | null;
  const sortSelect = document.getElementById('paper-sort') as HTMLSelectElement | null;
  const resultCount = document.getElementById('result-count') as HTMLElement | null;
  const activeFiltersBar = document.getElementById('active-filters-bar') as HTMLElement | null;
  const activeFilterTags = document.getElementById('active-filter-tags') as HTMLElement | null;
  const clearFiltersBtn = document.getElementById('clear-filters-btn') as HTMLButtonElement | null;
  const expandBtn = document.getElementById('chip-expand-btn') as HTMLButtonElement | null;
  const paperList = document.getElementById('paper-list') as HTMLElement | null;
  const allChips = Array.from(document.querySelectorAll<HTMLButtonElement>('#language-filters .chip'));
  const langChips = Array.from(document.querySelectorAll<HTMLButtonElement>('#language-filters .lang-filter-chip'));
  const rows = Array.from(document.querySelectorAll<HTMLElement>('#paper-list .paper-row'));
  let activeLanguage = 'all';
  let chipExpanded = false;
  const chipRow = document.getElementById('language-filters') as HTMLElement | null;

  // ── Collapse helpers ────────────────────────────────────────────────────────

  function measureFirstRow(): { firstRowChips: HTMLButtonElement[]; overflowChips: HTMLButtonElement[] } {
    const visible = langChips.filter(c => !c.hidden && c.style.display !== 'none');
    if (!visible.length) return { firstRowChips: [], overflowChips: [] };
    const firstTop = visible[0].getBoundingClientRect().top;
    const chipH   = visible[0].getBoundingClientRect().height;
    const threshold = firstTop + chipH * 0.5;
    return {
      firstRowChips: visible.filter(c => c.getBoundingClientRect().top < threshold),
      overflowChips: visible.filter(c => c.getBoundingClientRect().top >= threshold),
    };
  }

  function applyCollapse() {
    if (!expandBtn || !chipRow) return;
    chipRow.appendChild(expandBtn);

    // All mutations inside the rAF so the browser paints only the final collapsed state —
    // no intermediate full-width flash.
    requestAnimationFrame(() => {
      langChips.forEach(c => c.style.removeProperty('display'));
      expandBtn!.style.display = 'none';

      const { firstRowChips, overflowChips } = measureFirstRow();
      if (overflowChips.length === 0) return;

      // Capture row position before hiding anything
      const firstTop = firstRowChips[0].getBoundingClientRect().top;
      const chipH    = firstRowChips[0].getBoundingClientRect().height;

      const toHide = [...overflowChips];
      if (firstRowChips.length > 0) toHide.push(firstRowChips[firstRowChips.length - 1]);
      toHide.forEach(c => { c.style.display = 'none'; });

      let hiddenCount = toHide.length;
      expandBtn!.style.removeProperty('display');
      expandBtn!.setAttribute('aria-expanded', 'false');
      expandBtn!.textContent = `… +${hiddenCount} more`;
      expandBtn!.setAttribute('aria-label', `Show ${hiddenCount} more language filters`);

      // Loop: keep hiding chips until expand button lands on the first row.
      // getBoundingClientRect forces synchronous reflow so positions are always current.
      for (let i = 0; i < langChips.length; i++) {
        if (chipH === 0) break;
        if (Math.abs(expandBtn!.getBoundingClientRect().top - firstTop) <= chipH * 0.5) break;
        const stillVisible = langChips.filter(c => !c.hidden && c.style.display !== 'none');
        const extra = stillVisible[stillVisible.length - 1];
        if (!extra) break;
        extra.style.display = 'none';
        hiddenCount++;
        expandBtn!.textContent = `… +${hiddenCount} more`;
        expandBtn!.setAttribute('aria-label', `Show ${hiddenCount} more language filters`);
      }

    });
  }

  function expandChips() {
    if (!expandBtn || !chipRow) return;
    chipExpanded = true;

    // All work inside a single rAF so the browser paints only the final state.
    requestAnimationFrame(() => {
      // Show all chips first; keep button hidden so it doesn't affect first-row measurement.
      langChips.forEach(c => { if (!c.hidden) c.style.removeProperty('display'); });
      expandBtn!.style.display = 'none';

      const visible = langChips.filter(c => !c.hidden && c.style.display !== 'none');
      if (visible.length > 0) {
        const firstTop = visible[0].getBoundingClientRect().top;
        const chipH    = visible[0].getBoundingClientRect().height;
        const threshold = firstTop + chipH * 0.5;
        const firstRowChips = visible.filter(c => c.getBoundingClientRect().top < threshold);

        // Place button after the last chip on the first row.
        if (firstRowChips.length > 0) {
          firstRowChips[firstRowChips.length - 1].insertAdjacentElement('afterend', expandBtn!);
        }

        expandBtn!.style.removeProperty('display');
        expandBtn!.setAttribute('aria-expanded', 'true');
        expandBtn!.textContent = 'Show less';
        expandBtn!.setAttribute('aria-label', 'Show fewer language filters');

        // If the button still wraps (row too narrow), move it one chip earlier per iteration.
        for (let i = 0; i < langChips.length; i++) {
          if (chipH === 0) break;
          if (Math.abs(expandBtn!.getBoundingClientRect().top - firstTop) <= chipH * 0.5) break;
          const prev = expandBtn!.previousElementSibling as Element | null;
          if (!prev || !langChips.includes(prev as HTMLButtonElement) || prev.parentNode !== chipRow) break;
          chipRow!.insertBefore(expandBtn!, prev);
        }
      } else {
        expandBtn!.style.removeProperty('display');
        expandBtn!.setAttribute('aria-expanded', 'true');
        expandBtn!.textContent = 'Show less';
        expandBtn!.setAttribute('aria-label', 'Show fewer language filters');
      }
    });
  }

  function collapseChips() {
    chipExpanded = false;
    applyCollapse();
  }

  expandBtn?.addEventListener('click', () => {
    chipExpanded ? collapseChips() : expandChips();
  });

  window.addEventListener('resize', () => {
    if (!chipExpanded) applyCollapse();
  });

  // ── Language chip search ────────────────────────────────────────────────────

  function filterLangChips(query: string) {
    const q = query.trim().toLowerCase();
    langChips.forEach(chip => {
      chip.hidden = q.length > 0 && !(chip.dataset.lang || '').toLowerCase().includes(q);
    });
    if (activeLanguage !== 'all') {
      const activeChip = langChips.find(c => c.dataset.lang === activeLanguage);
      if (activeChip?.hidden || q.length === 0) { setActiveChip('all'); applyFilters(); }
    }
    if (chipExpanded) {
      langChips.forEach(c => { if (!c.hidden) c.style.removeProperty('display'); });
    } else {
      applyCollapse();
    }
  }

  function setActiveChip(lang: string) {
    allChips.forEach(c => c.classList.remove('active'));
    const target = allChips.find(c => c.dataset.lang === lang);
    if (target) target.classList.add('active');
    activeLanguage = lang;
  }

  // ── Paper filters ───────────────────────────────────────────────────────────

  function getClassFilter(): string {
    const v = sortSelect?.value ?? '';
    return v.startsWith('class-') ? v.slice(6) : 'all';
  }

  function updateFilterBar() {
    const searchTerm = searchInput?.value.trim() ?? '';
    const langTerm = langSearchInput?.value.trim() ?? '';
    const classFilter = getClassFilter();
    const tags: string[] = [];
    if (searchTerm) tags.push(`Title: "${searchTerm}"`);
    if (langTerm) tags.push(`Language search: "${langTerm}"`);
    if (activeLanguage !== 'all') tags.push(`Language: ${activeLanguage}`);
    if (classFilter !== 'all') tags.push(`Class: ${classFilter}`);
    const active = tags.length > 0;
    if (activeFiltersBar) activeFiltersBar.style.display = active ? '' : 'none';
    if (activeFilterTags) activeFilterTags.textContent = tags.join(' · ');
  }

  function applyFilters() {
    const searchTerm = searchInput?.value.trim().toLowerCase() ?? '';
    const classFilter = getClassFilter();
    let visible = 0;
    rows.forEach(row => {
      const rowSearch = row.dataset.search || '';
      const rowLanguages = (row.dataset.languages || '').split('|').filter(Boolean);
      const rowClasses = (row.dataset.classes || '').split(',').filter(Boolean);
      const matchesLanguage = activeLanguage === 'all' || rowLanguages.includes(activeLanguage);
      const matchesSearch = !searchTerm || rowSearch.includes(searchTerm);
      const matchesClass = classFilter === 'all' || rowClasses.includes(classFilter);
      const show = matchesLanguage && matchesSearch && matchesClass;
      // Hide the wrapper so the absolutely-positioned PDF link is hidden along with the row
      (row.parentElement as HTMLElement).style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (resultCount) {
      resultCount.textContent = visible === rows.length
        ? `${rows.length} papers`
        : `${visible} of ${rows.length} papers`;
    }
    updateFilterBar();
  }

  // ── Sort ────────────────────────────────────────────────────────────────────

  function sortPapers(mode: string) {
    if (!paperList) return;
    const sorted = [...rows].sort((a, b) => {
      switch (mode) {
        case 'lang-desc':    return parseInt(b.dataset.langCount || '0') - parseInt(a.dataset.langCount || '0');
        case 'lang-asc':     return parseInt(a.dataset.langCount || '0') - parseInt(b.dataset.langCount || '0');
        case 'resource-asc': return parseInt(a.dataset.minClass  || '5') - parseInt(b.dataset.minClass  || '5');
        case 'resource-desc':return parseInt(b.dataset.minClass  || '5') - parseInt(a.dataset.minClass  || '5');
        case 'title-asc':    return (a.dataset.title || '').localeCompare(b.dataset.title || '');
        case 'title-desc':   return (b.dataset.title || '').localeCompare(a.dataset.title || '');
        default:             return parseInt(a.dataset.index || '0') - parseInt(b.dataset.index || '0');
      }
    });
    // Append the wrapper (grid item) so the PDF link moves with its row
    sorted.forEach(row => paperList.appendChild(row.parentElement as HTMLElement));
  }

  // Popovers are now hover/focus driven; no global click-close needed.

  // ── Wire up ─────────────────────────────────────────────────────────────────

  allChips.forEach(chip => {
    chip.addEventListener('click', () => { setActiveChip(chip.dataset.lang || 'all'); applyFilters(); });
  });
  searchInput?.addEventListener('input', applyFilters);
  langSearchInput?.addEventListener('input', e => { filterLangChips((e.target as HTMLInputElement).value); updateFilterBar(); });
  sortSelect?.addEventListener('change', () => {
    const v = sortSelect.value;
    sortPapers(v.startsWith('class-') ? 'default' : v);
    applyFilters();
  });
  clearFiltersBtn?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    if (langSearchInput) { langSearchInput.value = ''; filterLangChips(''); }
    setActiveChip('all');
    if (sortSelect) sortSelect.value = 'default';
    sortPapers('default');
    applyFilters();
  });

  requestAnimationFrame(() => { applyCollapse(); applyFilters(); });
</script>
