---
import BaseLayout from '../layouts/BaseLayout.astro';
import PaperTable from '../components/PaperTable.astro';
import { loadSiteData } from '../lib/data.js';

const data = loadSiteData(7);
---
<BaseLayout title="LangTrend Papers" description="Filterable paper list for detected language mentions">
  <section class="page-intro">
    <h1>Flagged papers</h1>
    <p>Search and filter the current snapshot by language mentions.</p>
  </section>

  <PaperTable flaggedPapers={data.flaggedPapers} />
</BaseLayout>
