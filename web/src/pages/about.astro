---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadSiteData } from '../lib/data.js';

const data = loadSiteData(undefined, 7);
const classes = (data.languageData.lang_classes || {}) as Record<string, unknown[]>;
const classDescriptions: Record<string, string> = {
  '0': 'Have exceptionally limited resources, and have rarely been considered in language technologies.',
  '1': 'Have some unlabelled data; however, collecting labelled data is challenging.',
  '2': 'A small set of labelled datasets has been collected, and language support communities are there to support the language.',
  '3': 'Has a strong web presence, and a cultural community that backs it. Have been highly benefited by unsupervised pre-training.',
  '4': 'Have a large amount of unlabelled data, and lesser, but still a significant amount of labelled data. have dedicated NLP communities researching these languages.',
  '5': 'Have a dominant online presence. There have been massive investments in the development of resources and technologies.',
};

const classRows = Object.entries(classes)
  .sort(([left], [right]) => Number(left) - Number(right))
  .map(([classId, languages]) => ({
    classId,
    description: classDescriptions[classId] || '',
    count: languages.length,
    examples: languages.slice(0, 2).map((language) => String(language)).join(', '),
  }));

const classExamples: Record<string, string[]> = {
  '0': ['Pinyin', 'Irarutu', 'Himarimã'],
  '1': ['Hawaiian', 'Frisian', 'Nahuatl'],
  '2': ['Sinhala', 'Irish', 'Zulu'],
  '3': ['Hindi', 'Tamil', 'Urdu'],
  '4': ['Indonesian', 'Russian', 'Italian'],
  '5': ['Arabic', 'Chinese', 'English'],
};

// Replace the examples field with explicit examples when provided, otherwise use repo data
for (const row of classRows) {
  if (classExamples[row.classId]) {
    row.examples = classExamples[row.classId].slice(0, 3).join(', ');
  }
}
---
<BaseLayout title="About LangTrend" description="Pipeline, limits, and references for LangTrend">
  <section class="page-intro">
    <h1>How does this work?</h1>
    <p>Pipeline notes, language classes, references, and planned digest integrations.</p>
  </section>

  <section class="panel about-grid">
    <article>
      <h2>Pipeline diagram</h2>
      <div class="diagram-placeholder">Placeholder for pipeline diagram</div>
    </article>
  </section>

  <section class="panel">
    <div class="panel-head">
      <h2>Language classes</h2>
    </div>
    <table class="class-table">
      <thead>
        <tr><th>Class</th><th>Description<sup>1</sup></th><th>Count<sup>2</sup></th><th>Examples<sup>2</sup></th></tr>
      </thead>
      <tbody>
        {classRows.map((row) => (
          <tr>
            <td>Class {row.classId}</td>
            <td>{row.description}</td>
            <td>{row.count}</td>
            <td>{row.examples}</td>
          </tr>
        ))}
      </tbody>
    </table>
    <div class="table-notes">
      <p><sup>1</sup> Class descriptions are adapted from <a href="https://aclanthology.org/2020.acl-main.560/" target="_blank" rel="noreferrer"><u>Joshi et al. [3]</u></a>.</p>
      <p><sup>2</sup> Counts and example languages are updated from the <a href="https://github.com/NisansaDdS/Some-Languages-are-More-Equal-than-Others" target="_blank" rel="noreferrer"><u>Some Languages are More Equal than Others</u></a> repository, which follows the work from <a href="https://doi.org/10.18653/v1/2022.aacl-main.62" target="_blank" rel="noreferrer"><u>Ranathunga and de Silva [2]</u></a>.</p>
    </div>
  </section>

  <section class="panel about-grid">
    <article>
      <h2>Limitations</h2>
      <ul class="info-list">
        <li>Language detection is heuristic and title/abstract-driven.</li>
        <li>HTML extraction only works when arXiv exposes the HTML page.</li>
        <li>The first release targets weekly snapshots, not real-time ingestion.</li>
      </ul>
    </article>
    <!-- Digest subscription section removed temporarily -->
  </section>
  <section class="panel">
    <article>
      <h2>References</h2>
      <ol class="ref-list">
        <li>S. Ranathunga, N. De Silva, D. Jayakody, and A. Fernando, “Shoulders of Giants: A Look at the Degree and Utility of Openness in NLP Research,” in Proceedings of the 62nd Annual Meeting of the Association for Computational Linguistics (Volume 2: Short Papers), L.-W. Ku, A. Martins, and V. Srikumar, Eds., Bangkok, Thailand: Association for Computational Linguistics, Aug. 2024, pp. 519–529. doi: 10.18653/v1/2024.acl-short.48.</li>
        <li>S. Ranathunga and N. de Silva, “Some Languages are More Equal than Others: Probing Deeper into the Linguistic Disparity in the NLP World,” in Proceedings of the 2nd Conference of the Asia-Pacific Chapter of the Association for Computational Linguistics and the 12th International Joint Conference on Natural Language Processing (Volume 1: Long Papers), Y. He, H. Ji, S. Li, Y. Liu, and C.-H. Chang, Eds., Online only: Association for Computational Linguistics, Nov. 2022, pp. 823–848. doi: 10.18653/v1/2022.aacl-main.62.</li>
        <li>P. Joshi, S. Santy, A. Budhiraja, K. Bali, and M. Choudhury, “The State and Fate of Linguistic Diversity and Inclusion in the NLP World,” in Proceedings of the 58th Annual Meeting of the Association for Computational Linguistics, D. Jurafsky, J. Chai, N. Schluter, and J. Tetreault, Eds., Online: Association for Computational Linguistics, Jul. 2020, pp. 6282–6293. doi: 10.18653/v1/2020.acl-main.560.
        </li>
        <li>C. Auer et al., “Docling Technical Report,” 2024, arXiv. doi: 10.48550/ARXIV.2408.09869.
        </li>
      </ol>
    </article>
  </section>
</BaseLayout>
