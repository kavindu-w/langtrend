---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrendCharts from '../components/TrendCharts.astro';
import PaperTable from '../components/PaperTable.astro';
import WeekCalendar from '../components/WeekCalendar.astro';
import { loadSiteData, getAvailableWeeks, loadAllWeeksData } from '../lib/data.js';

const data = loadSiteData();
const availableWeeks = getAvailableWeeks();
const allWeeksData = loadAllWeeksData();
const currentYear = new Date().getFullYear();
---
<BaseLayout title="LangTrend" description="Automated dashboard for language inclusion in NLP research">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Weekly arXiv Computation and Language (cs.CL) Paper Language Inclusion Tracker</p>
      <h1>LangTrend</h1>
      <p class="hero-text">
        NLP research coverage isn't evenly distributed. LangTrend tracks which languages feature in new cs.CL papers each week, offering an interactive explorer, clear trends, and thorough stats.
      </p>
      <div class="hero-actions">
        <a class="primary-btn" href="#statistics">
          <svg class="navicon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M5 19h14v2H3V3h2v16Zm3-3V8h3v8H8Zm5 0V5h3v11h-3Zm5 0v-6h3v6h-3Z" fill="currentColor" />
          </svg>
          <span>Browse Statistics</span>
        </a>
        <a class="secondary-btn" href={`${import.meta.env.BASE_URL}about/`}>
          <svg class="navicon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M11 10h2v7h-2zm0-4h2v2h-2z" fill="currentColor" />
            <path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm0 18a8 8 0 1 1 0-16 8 8 0 0 1 0 16Z" fill="currentColor" />
          </svg>
          <span>About The Pipeline</span>
        </a>
      </div>
    </div>

    <WeekCalendar activeWeek={data.manifest.week_start ?? undefined} availableWeeks={availableWeeks} />
  </section>

  <details id="flagged-papers" class="paper-collapse panel" open>
    <summary class="paper-collapse-summary">
      <div>
        <h2>Papers Mentioning Languages</h2>
        <p>Papers with detected language mentions. Click a row to expand its abstract.</p>
      </div>
      <span class="paper-collapse-hint">Collapse section</span>
    </summary>
    <PaperTable flaggedPapers={data.flaggedPapers} languageData={data.languageData} />
  </details>

  <details id="statistics" class="stats-collapse panel" open>
    <summary class="paper-collapse-summary">
      <div>
        <h2>Statistics</h2>
        <p>Weekly scan summary and overall language trend.</p>
      </div>
      <span class="paper-collapse-hint">Collapse section</span>
    </summary>
    <div class="dashboard-section">
      <TrendCharts
        manifest={data.manifest}
        languageData={data.languageData}
        languageCounts={data.languageCounts}
        classCounts={data.classCounts}
        weekSeries={data.weekSeries}
        coverageStats={data.coverageStats}
        allWeeksData={allWeeksData}
      />
    </div>
  </details>

  <footer class="page-footer panel">
    <h2>Contact</h2>
    <a
      class="footer-link footer-mail"
      href="mailto:akwarnakulasuriya@gmail.com"
      aria-label="Email awarnakulasuriya@gmail.com"
      title="Email awarnakulasuriya@gmail.com"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path
          d="M4 5h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Zm0 2v.23l8 5.33 8-5.33V7H4Zm16 10V9.57l-7.45 4.96a1 1 0 0 1-1.1 0L4 9.57V17h16Z"
          fill="currentColor"></path>
      </svg>
      <span>Email</span>
    </a>
    <a
      class="footer-link footer-github"
      href="https://github.com/kavindu-w/langtrend"
      target="_blank"
      rel="noreferrer"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path
          d="M12 2C6.48 2 2 6.48 2 12.02c0 4.42 2.87 8.17 6.84 9.49.5.09.66-.22.66-.48 0-.24-.01-.87-.02-1.71-2.78.61-3.37-1.34-3.37-1.34-.46-1.17-1.12-1.49-1.12-1.49-.92-.63.07-.62.07-.62 1.02.07 1.56 1.05 1.56 1.05.9 1.54 2.36 1.1 2.93.84.09-.66.35-1.1.64-1.35-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.99 1.03-2.69-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.03a9.5 9.5 0 0 1 5 0c1.9-1.3 2.74-1.03 2.74-1.03.55 1.37.2 2.39.1 2.64.64.7 1.02 1.6 1.02 2.69 0 3.84-2.34 4.69-4.57 4.94.36.31.68.92.68 1.86 0 1.34-.01 2.42-.01 2.75 0 .26.17.57.67.47A10.02 10.02 0 0 0 22 12.02C22 6.48 17.52 2 12 2Z"
          fill="currentColor"></path>
      </svg>
      <span>GitHub<span class="sr-only"> (opens in new tab)</span></span>
    </a>
    <p class="copyright-line">
      © {currentYear} LangTrend. All rights reserved.
    </p>
  </footer>
</BaseLayout>
