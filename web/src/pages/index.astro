---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatCards from '../components/StatCards.astro';
import TrendCharts from '../components/TrendCharts.astro';
import PaperTable from '../components/PaperTable.astro';
import { loadSiteData, colorForLanguage } from '../lib/data.js';

const data = loadSiteData(7);
const recentPapers = data.flaggedPapers.slice(0, 5);

type RecentPaper = {
  paper: {
    title: string;
    authors: string[];
  };
  languages: Array<string | { language?: string | null }>;
};

type WeekPoint = {
  date: string;
  papers: number;
  flagged: number;
};
---
<BaseLayout title="LangTrend" description="Automated dashboard for language inclusion in NLP research">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Automated NLP language-tracking dashboard</p>
      <h1>LangTrend</h1>
      <p class="hero-text">
        Weekly arXiv mining, language detection, and research trend summaries for NLP and CL.
      </p>
      <div class="hero-actions">
        <a class="primary-btn" href="/papers">Browse papers</a>
        <a class="secondary-btn" href="/about">About the pipeline</a>
      </div>
    </div>

    <aside class="calendar-card">
      <div class="panel-head compact-head">
        <h2>Week view</h2>
        <p>Latest rolling snapshot.</p>
      </div>
      <div class="calendar-list">
        {data.weekSeries.length > 0 ? data.weekSeries.map((item: WeekPoint) => (
          <div class="calendar-item">
            <strong>{item.date}</strong>
            <span>{item.papers} papers</span>
            <span>{item.flagged} flagged</span>
          </div>
        )) : <p class="placeholder-text">Calendar will populate after the first snapshot.</p>}
      </div>
    </aside>
  </section>

  <StatCards manifest={data.manifest} />
  <TrendCharts languageCounts={data.languageCounts} weekSeries={data.weekSeries} topLanguages={data.topLanguages} />

  <section class="panel featured-panel">
    <div class="panel-head">
      <h2>Featured flagged papers</h2>
      <p>Current snapshot sample with language tiles.</p>
    </div>
    <div class="featured-list">
      {recentPapers.length > 0 ? recentPapers.map((item: RecentPaper) => (
        <article class="featured-paper">
          <div>
            <h3>{item.paper.title}</h3>
            <p>{item.paper.authors.join(', ')}</p>
          </div>
          <div class="featured-tags">
            {item.languages.map((entry: string | { language?: string | null }) => {
              const language = typeof entry === 'string' ? entry : entry?.language ?? '';
              return language ? <span class="lang-chip" style={`background:${colorForLanguage(language)}`}>{language}</span> : null;
            })}
          </div>
        </article>
      )) : <p class="placeholder-text">No flagged papers yet.</p>}
    </div>
  </section>

  <PaperTable flaggedPapers={data.flaggedPapers} />
</BaseLayout>
